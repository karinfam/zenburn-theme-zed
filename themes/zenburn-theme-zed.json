{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Zenburn",
  "author": "Karin Fam",
  "themes": [
    {
      "name": "Zenburn",
      "appearance": "dark",
      "style": {
        "background": "#3F3F3F",
        "editor.background": "#3F3F3F",
        "editor.foreground": "#DCDCCC",
        "editor.gutter.background": "#3F3F3F",
        "editor.subheader.background": "#3F3F3F",
        "editor.line_number": "#8F8F8F",
        "editor.active_line_number": "#DCDCCC",
        "editor.active_line.background": "#38383899",
        "surface.background": "#3F3F3F",
        "elevated_surface.background": "#3F3F3F",
        "panel.background": "#3F3F3F",
        "status_bar.background": "#3F3F3F",
        "title_bar.background": "#3F3F3F",
        "title_bar.inactive_background": "#3F3F3F",
        "toolbar.background": "#3F3F3F",
        "tab_bar.background": "#3F3F3F",
        "tab.inactive_background": "#3F3F3F",
        "tab.active_background": "#3F3F3F",
        "terminal.background": "#3F3F3F",
        "text": "#DCDCCC",
        "text.muted": "#8F8F8F",
        "border": "#2B2B2B",
        "players": [
          { "cursor": "#FFFFEFFF", "background": "#FFFFEFFF", "selection": "#41414166" }
        ],
        "syntax": {
          "comment":     { "color": "#7F9F7F" },
          "comment.doc": { "color": "#7F9F7F" },
          "string":      { "color": "#CC9393" },
          "number":      { "color": "#8CD0D3" },
          "constant":    { "color": "#8CD0D3" },
          "boolean":     { "color": "#8CD0D3" },
          "variable":    { "color": "#DCDCCC" },
          "keyword":     { "color": "#F0DFAF" },
          "function":    { "color": "#EFEF8F" },
          "type":        { "color": "#7CB8BB" }
        }
      }
    }
  ]
}
